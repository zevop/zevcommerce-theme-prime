{
  "name": "Prime",
  "settings": {
    "colors": {
      "primary": "#111827",
      "secondary": "#4B5563",
      "accent": "#6366f1",
      "background": "#ffffff",
      "text": "#4B5563",
      "heading": "#111827",
      "border": "#E5E7EB",
      "shadow": "rgba(0,0,0,0.05)",
      "link": "#2563EB",
      "linkHover": "#1D4ED8",
      "buttonBg": "#111827",
      "buttonText": "#ffffff",
      "buttonBorder": "#111827",
      "buttonHoverBg": "#374151",
      "buttonHoverText": "#ffffff",
      "buttonHoverBorder": "#374151",
      "secondaryButtonBg": "#ffffff",
      "secondaryButtonText": "#111827",
      "secondaryButtonBorder": "#D1D5DB",
      "secondaryButtonHoverBg": "#F9FAFB",
      "secondaryButtonHoverText": "#111827",
      "secondaryButtonHoverBorder": "#9CA3AF",
      "inputBg": "#ffffff",
      "inputText": "#111827",
      "inputBorder": "#D1D5DB",
      "inputHoverBg": "#F9FAFB",
      "variantBg": "#ffffff",
      "variantText": "#4B5563",
      "variantBorder": "#E5E7EB",
      "variantSelectedBg": "#111827",
      "variantSelectedText": "#ffffff",
      "variantSelectedBorder": "#111827"
    },
    "typography": {
      "headingFont": "Outfit",
      "bodyFont": "Inter",
      "subheadingFont": "Inter",
      "accentFont": "Playfair Display",
      "p": {
        "size": "16px",
        "lineHeight": "1.6",
        "letterSpacing": "normal",
        "case": "default"
      },
      "h1": {
        "font": "heading",
        "size": "48px",
        "lineHeight": "1.1",
        "letterSpacing": "-0.02em",
        "case": "default"
      },
      "h2": {
        "font": "heading",
        "size": "36px",
        "lineHeight": "1.2",
        "letterSpacing": "-0.01em",
        "case": "default"
      },
      "h3": {
        "font": "heading",
        "size": "30px",
        "lineHeight": "1.3",
        "letterSpacing": "-0.01em",
        "case": "default"
      },
      "h4": {
        "font": "heading",
        "size": "24px",
        "lineHeight": "1.3",
        "letterSpacing": "normal",
        "case": "default"
      },
      "h5": {
        "font": "heading",
        "size": "20px",
        "lineHeight": "1.4",
        "letterSpacing": "normal",
        "case": "default"
      },
      "h6": {
        "font": "heading",
        "size": "16px",
        "lineHeight": "1.4",
        "letterSpacing": "normal",
        "case": "default"
      }
    },
    "layout": {
      "containerWidth": "1280px",
      "sectionSpacing": "64px",
      "sectionSpacingMobile": "40px",
      "gridGap": "32px"
    },
    "animations": {
      "pageTransition": "fade",
      "cardHoverEffect": "lift",
      "scrollReveal": "fade-up",
      "scrollRevealDuration": 600,
      "staggerChildren": true
    },
    "buttons": {
      "primaryRadius": "6px",
      "primaryBorderThickness": "0px",
      "primaryFont": "body",
      "primaryCase": "default",
      "secondaryRadius": "6px",
      "secondaryBorderThickness": "1px",
      "secondaryFont": "body",
      "secondaryCase": "default",
      "pillsRadius": "100px"
    },
    "badges": {
      "position": "top_left",
      "radius": "4px",
      "saleBg": "#DC2626",
      "saleText": "#ffffff",
      "soldOutBg": "#9CA3AF",
      "soldOutText": "#ffffff",
      "font": "body",
      "case": "uppercase"
    },
    "cart": {
      "type": "drawer",
      "titleCase": "default",
      "priceFont": "body",
      "autoOpenDrawer": true,
      "emptyCartLink": "/collections/all",
      "enableNotes": false,
      "openNoteByDefault": false,
      "enableDiscounts": true,
      "mediaBorder": "none",
      "mediaRadius": "6px"
    },
    "drawers": {
      "colorScheme": "light",
      "borders": "none",
      "shadow": "md"
    },
    "icons": {
      "stroke": "default"
    },
    "inputs": {
      "borderThickness": "1px",
      "radius": "6px",
      "textPreset": "p"
    },
    "modals": {
      "colorScheme": "light",
      "radius": "12px",
      "borders": "none",
      "shadow": "xl"
    },
    "productCards": {
      "quickAdd": true,
      "mobileQuickAdd": true,
      "quickAddScheme": "white",
      "showSecondImage": true,
      "showCarousel": false
    }
  },
  "sections": {
    "announcement_1": {
      "type": "announcement",
      "settings": {},
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text": "Welcome to our store",
            "background_color": "#111827",
            "text_color": "#ffffff"
          }
        }
      ]
    },
    "header_1": {
      "type": "header",
      "settings": {
        "menuHandle": "main-menu"
      }
    },
    "hero_1": {
      "type": "hero",
      "settings": {
        "height": "large",
        "alignment": "center",
        "vertical_alignment": "center"
      },
      "blocks": [
        {
          "type": "heading",
          "settings": {
            "text": "Welcome to {{store_name}}",
            "size": "h1"
          }
        },
        {
          "type": "text",
          "settings": {
            "text": "Discover our curated collection of premium products, designed for your lifestyle."
          }
        },
        {
          "type": "button",
          "settings": {
            "text": "Shop Now",
            "link": "/collections/all"
          }
        }
      ]
    },
    "product_grid_1": {
      "type": "product-grid",
      "settings": {
        "padding_top": 80,
        "padding_bottom": 80,
        "image_ratio": "portrait"
      },
      "blocks": [
        {
          "type": "heading",
          "settings": {
            "text": "Featured Collection",
            "size": "lg",
            "alignment": "left"
          }
        },
        {
          "type": "product_grid_items",
          "settings": {
            "limit": 8,
            "columns_desktop": "4",
            "image_ratio": "portrait"
          }
        }
      ]
    },
    "icons_with_text_1": {
      "type": "icons_with_text",
      "settings": {
        "title": "",
        "columns": "3",
        "padding_top": 48,
        "padding_bottom": 48
      },
      "blocks": [
        {
          "type": "icon_item",
          "settings": {
            "icon": "truck",
            "title": "Free Shipping",
            "text": "On all orders over $50"
          }
        },
        {
          "type": "icon_item",
          "settings": {
            "icon": "shield",
            "title": "Secure Payments",
            "text": "100% protected checkout"
          }
        },
        {
          "type": "icon_item",
          "settings": {
            "icon": "headphones",
            "title": "24/7 Support",
            "text": "We're here to help anytime"
          }
        }
      ]
    },
    "image_with_text_1": {
      "type": "image_with_text",
      "settings": {
        "padding_top": 80,
        "padding_bottom": 80
      },
      "blocks": [
        {
          "type": "heading",
          "settings": {
            "text": "Our Story",
            "size": "h2"
          }
        },
        {
          "type": "text",
          "settings": {
            "text": "We believe in quality, craftsmanship, and timeless design. Every product in our collection is carefully curated to bring you the very best."
          }
        },
        {
          "type": "button",
          "settings": {
            "text": "Learn More",
            "link": "/pages/about"
          }
        }
      ]
    },
    "testimonials_1": {
      "type": "testimonials",
      "settings": {
        "layout": "carousel",
        "autoplay": true,
        "autoplay_speed": 5,
        "show_stars": true,
        "show_quote_mark": true,
        "padding_top": 80,
        "padding_bottom": 80,
        "background_color": "#F9FAFB"
      },
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "The quality of the products exceeded my expectations. I've been a loyal customer for over a year now.",
            "author": "Sarah Johnson",
            "title": "Verified Buyer",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "Fast shipping, beautiful packaging, and the customer service is outstanding. Highly recommended!",
            "author": "Michael Chen",
            "title": "Repeat Customer",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "Finally found a store that delivers on its promises. Premium quality at fair prices.",
            "author": "Emily Rodriguez",
            "title": "Happy Customer",
            "rating": 5
          }
        }
      ]
    },
    "newsletter_1": {
      "type": "newsletter",
      "settings": {
        "layout": "stacked",
        "padding_top": 80,
        "padding_bottom": 80,
        "background_color": "#111827",
        "text_color": "#ffffff"
      },
      "blocks": [
        {
          "type": "heading",
          "settings": {
            "text": "Stay in the Loop",
            "size": "h2",
            "color": "#ffffff"
          }
        },
        {
          "type": "text",
          "settings": {
            "text": "Subscribe to get special offers, early access to new arrivals, and insider-only discounts.",
            "color": "#D1D5DB"
          }
        },
        {
          "type": "email_signup",
          "settings": {
            "placeholder": "Enter your email",
            "button_text": "Subscribe"
          }
        }
      ]
    },
    "footer_1": {
      "type": "footer",
      "settings": {
        "description": "Premium e-commerce experiences built for conversion and scale.",
        "showSocials": true,
        "backgroundColor": "#F9FAFB",
        "alignment": "left"
      },
      "blocks": [
        {
          "type": "link_list",
          "settings": {
            "title": "Shop",
            "menu": "main-menu",
            "column_index": 1
          }
        },
        {
          "type": "link_list",
          "settings": {
            "title": "Support",
            "menu": "footer",
            "column_index": 2
          }
        },
        {
          "type": "social_link",
          "settings": {
            "platform": "instagram",
            "url": "https://instagram.com",
            "column_index": 3
          }
        }
      ]
    },
    "copyright_1": {
      "type": "copyright",
      "settings": {
        "copyrightText": "",
        "backgroundColor": "#F9FAFB",
        "showBorder": true
      }
    },
    "main-product": {
      "type": "product-detail",
      "settings": {
        "layout": "2-col"
      },
      "blocks": [
        {
          "type": "product_images",
          "settings": {
            "layout": "stacked",
            "enable_zoom": true,
            "show_thumbnails": true
          }
        },
        {
          "type": "product_title",
          "settings": {
            "show_vendor": true
          }
        },
        {
          "type": "product_price",
          "settings": {
            "show_compare_at": true
          }
        },
        {
          "type": "product_variants",
          "settings": {
            "style": "buttons"
          }
        },
        {
          "type": "add_to_cart",
          "settings": {
            "show_quantity": true,
            "button_text": "Add to Cart"
          }
        },
        {
          "type": "product_description",
          "settings": {}
        }
      ]
    },
    "main-collection": {
      "type": "product-list",
      "settings": {},
      "blocks": [
        {
          "type": "collection_heading",
          "settings": {}
        },
        {
          "type": "collection_description",
          "settings": {}
        },
        {
          "type": "product_grid",
          "settings": {
            "columns": "4"
          }
        }
      ]
    },
    "main-cart": {
      "type": "cart-page",
      "settings": {},
      "blocks": [
        {
          "type": "cart_items",
          "settings": {}
        },
        {
          "type": "cart_summary",
          "settings": {}
        }
      ]
    },
    "main-login": {
      "type": "auth-section",
      "settings": {
        "mode": "login"
      },
      "blocks": [
        {
          "type": "auth_header",
          "allow_delete": false,
          "settings": {
            "title": "Welcome back",
            "subtitle": "Sign in to your account",
            "show_logo": true
          }
        },
        {
          "type": "login_form",
          "allow_delete": false,
          "settings": {
            "show_forgot_password": true,
            "show_register_link": true,
            "button_text": "Sign In"
          }
        }
      ]
    },
    "main-register": {
      "type": "auth-section",
      "settings": {
        "mode": "register"
      },
      "blocks": [
        {
          "type": "auth_header",
          "allow_delete": false,
          "settings": {
            "title": "Create account",
            "subtitle": "Join us today",
            "show_logo": true
          }
        },
        {
          "type": "register_form",
          "allow_delete": false,
          "settings": {
            "show_terms": true,
            "show_login_link": true,
            "button_text": "Create Account"
          }
        }
      ]
    },
    "main-forgot-password": {
      "type": "auth-section",
      "settings": {
        "mode": "forgot-password"
      },
      "blocks": [
        {
          "type": "auth_header",
          "allow_delete": false,
          "settings": {
            "title": "Reset Password",
            "subtitle": "We'll send you a code to reset your password",
            "show_logo": true
          }
        },
        {
          "type": "forgot_password_form",
          "allow_delete": false,
          "settings": {
            "button_text": "Send Code"
          }
        }
      ]
    },
    "main-checkout": {
      "type": "checkout-page",
      "blocks": [
        {
          "type": "checkout_page_title",
          "settings": {
            "show_title": true,
            "title": "Checkout",
            "alignment": "left",
            "color": "#000000"
          }
        },
        {
          "type": "checkout_form",
          "settings": {}
        }
      ],
      "settings": {}
    },
    "main-thank-you": {
      "type": "thank-you-page",
      "blocks": [
        {
          "type": "thank_you_icon",
          "settings": {
            "mode": "icon",
            "icon": "check",
            "size": 80,
            "color": "#16a34a",
            "background_color": "#f0fdf4"
          }
        },
        {
          "type": "thank_you_header",
          "settings": {
            "show_title": true,
            "title": "Order Placed!",
            "subtitle": "Thank you for your purchase. Your order has been successfully placed."
          }
        },
        {
          "type": "order_details",
          "settings": {}
        },
        {
          "type": "gift_card_codes",
          "settings": {}
        },
        {
          "type": "payment_instructions",
          "settings": {}
        },
        {
          "type": "continue_shopping",
          "settings": {
            "button_text": "Continue Shopping"
          }
        }
      ],
      "settings": {}
    },
    "main-account": {
      "type": "account-section",
      "blocks": [
        {
          "type": "account_nav",
          "allow_delete": false,
          "settings": {
            "use_soft_active": true,
            "active_color": "#F3F4F6",
            "active_text_color": "#111827",
            "active_shadow": "none",
            "icon_color": "#9CA3AF",
            "active_icon_color": "#111827"
          }
        },
        {
          "type": "report",
          "settings": {
            "show_total_orders": true,
            "show_total_spent": true,
            "show_loyalty": true,
            "card_bg": "#FFFFFF",
            "icon_color": "#111827",
            "icon_bg": "#F9FAFB",
            "label_color": "#6B7280",
            "value_color": "#111827"
          }
        },
        {
          "type": "orders",
          "allow_delete": false,
          "settings": {
            "dashboard_title": "Recent Orders",
            "dashboard_items": 3,
            "items_per_page": 10,
            "search_enabled": true,
            "table_bg": "#FFFFFF",
            "header_bg": "#F9FAFB",
            "header_text_color": "#9CA3AF",
            "row_text_color": "#111827",
            "row_border_color": "#F3F4F6"
          }
        },
        {
          "type": "addresses",
          "allow_delete": false,
          "settings": {
            "title": "Saved Addresses",
            "card_bg": "#FFFFFF",
            "title_color": "#111827",
            "text_color": "#6B7280",
            "icon_color": "#D1D5DB"
          }
        }
      ],
      "settings": {
        "show_header": true,
        "title": "My Account",
        "padding_top": 64,
        "padding_bottom": 64,
        "content_width": "1200",
        "background_color": "#FFFFFF",
        "shadow_style": "none",
        "border_radius": 12,
        "show_recent_orders": true,
        "show_recent_addresses": true,
        "modal_bg": "rgba(0,0,0,0.5)",
        "modal_title": "Add New Address",
        "modal_cancel_label": "Cancel",
        "modal_submit_label": "Save Address",
        "modal_content_bg": "#FFFFFF",
        "modal_radius": 20,
        "modal_primary_button_bg": "#111827",
        "modal_primary_button_text": "#FFFFFF",
        "modal_title_color": "#111827",
        "modal_input_bg": "#F9FAFB",
        "modal_input_border": "#E5E7EB"
      }
    },
    "main-order": {
      "type": "order-details-section",
      "blocks": [
        {
          "type": "order_header",
          "settings": {}
        },
        {
          "type": "order_items",
          "settings": {}
        },
        {
          "type": "order_summary",
          "settings": {}
        },
        {
          "type": "order_address",
          "settings": {}
        }
      ],
      "settings": {}
    },
    "main-search": {
      "type": "search-section",
      "settings": {
        "padding_top": 64,
        "padding_bottom": 64
      }
    },
    "main-not-found": {
      "type": "not-found-section",
      "settings": {
        "padding_top": 80,
        "padding_bottom": 80
      }
    }
  },
  "layout": {
    "header": [
      "announcement_1",
      "header_1"
    ],
    "content": [
      "hero_1",
      "icons_with_text_1",
      "product_grid_1",
      "image_with_text_1",
      "testimonials_1",
      "newsletter_1"
    ],
    "footer": [
      "footer_1",
      "copyright_1"
    ]
  },
  "templates": {
    "product_detail": {
      "order": [
        "main-product"
      ]
    },
    "collection": {
      "order": [
        "main-collection"
      ]
    },
    "cart": {
      "order": [
        "main-cart"
      ]
    },
    "login": {
      "order": [
        "main-login"
      ]
    },
    "register": {
      "order": [
        "main-register"
      ]
    },
    "forgot_password": {
      "order": [
        "main-forgot-password"
      ]
    },
    "checkout": {
      "order": [
        "main-checkout"
      ]
    },
    "thank_you": {
      "order": [
        "main-thank-you"
      ]
    },
    "account": {
      "order": [
        "main-account"
      ]
    },
    "order": {
      "order": [
        "main-order"
      ]
    },
    "search": {
      "order": [
        "main-search"
      ]
    },
    "not_found": {
      "order": [
        "main-not-found"
      ]
    }
  }
}